  id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  formid             String              @unique
  email              String?
  fullname           String
  permanentaddress   String?
  residentialaddress String?
  vehicletype        String?
  mobile             String?
  altcontact         String?
  reason             String?
  strengthsweakness  String?
  goals5years        String?
  applyposition      String?
  positiontype       String?
  aadharurl          String[]
  panurl             String[]
  cvurl              String?
  driverlicenseurl   String?
  vehicledocsurl     String[]
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  status             String?             @default("pending")
  application_status String?             @default("pending")
  employment_status  String?
  blood_group        String?
  employee_contracts employee_contracts?

  @@schema("public")
}

model feedbacks {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String?
  email      String?
  message    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model lottery_entries {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  address        String
  mobile         String
  email          String
  age            Int
  lottery_number String
  created_at     DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@schema("public")
}

model pass_cards {
  id                      BigInt                   @id @default(autoincrement())
  registration_no         String                   @unique
  participant_name        String
  competition             String
  event_date              String?
  event_time              String?
  venue                   String?
  approved                Boolean?                 @default(false)
  created_at              DateTime?                @default(now()) @db.Timestamptz(6)
  registration_id         BigInt?
  book_fair_registrations book_fair_registrations? @relation(fields: [registration_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model place_ratings {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  place_id   String
  rating     Int
  device_id  String
  created_at DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@index([device_id], map: "idx_place_ratings_device_id")
  @@index([place_id], map: "idx_place_ratings_place_id")
  @@schema("public")
}

model places {
  id            Int        @id @default(autoincrement())
  name          String
  type          String
  latitude      Float?
  longitude     Float?
  rating        Decimal?   @db.Decimal(2, 1)
  opening_hours String?
  image_url     String?
  description   String?
  contact       String?    @db.VarChar(100)
  start_date    DateTime?  @db.Date
  end_date      DateTime?  @db.Date
  price         Decimal?   @db.Decimal(10, 2)
  location      String?    @db.VarChar(255)
  features      String[]
  category      String?
  user_id       String?    @db.Uuid
  ads           String?
  ads_url       String?
  ads_no        Int?
  nearby_places String?
  off_day       String?
  tips          String?
  bookings      bookings[]
  carts         carts[]
  comments      comments[]
  users         users?     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@schema("public")
}

model route_rates {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pickup_location    String
  drop_location      String
  std_rate           Decimal? @db.Decimal
  instant_rate       Decimal? @db.Decimal
  light_vehicle_rate Decimal? @db.Decimal

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model student_registrations {
  id              BigInt    @id @default(autoincrement())
  name            String
  phone           String
  address         String
  school          String
  class           String
  stream          String?
  interest        String?
  giveaway_number String
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

